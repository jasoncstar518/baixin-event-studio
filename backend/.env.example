# 后端环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DATABASE_URL="postgresql://baixin:baixin123@localhost:5432/baixin_event_studio"

# Redis 配置
REDIS_URL="redis://localhost:6379"

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 文件存储（OSS/S3）
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_REGION=

# 邮件服务（用于密码找回）
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# 第三方登录（可选）
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
